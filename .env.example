# Required
TRELLO_KEY=
TRELLO_TOKEN=

# Recommended for signature verification
TRELLO_SECRET=
WEBHOOK_CALLBACK_URL=

# Behavior
DOING_LIST_NAME=Doing
STATE_PATH=./trello-state.json

# Notify via OpenClaw Gateway (send message into your existing Telegram chat)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_TARGET_CHAT=telegram:105322994

# For webhook registration
TRELLO_IDMODEL=

PORT=3000
